generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  countries   String
  duration    Int
  travelers   String
  budget      Int
  interests   String
  travelMonth String
  archetypeId String
  itinerary   String
  createdAt   DateTime @default(now())
}
